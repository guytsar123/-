# ===== WhatsApp Cloud API (Meta) =====
# מ-Meta for Developers > האפליקציה שלך > WhatsApp > API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here
PHONE_NUMBER_ID=your_phone_number_id_here
# טוקן שאתה ממציא בעצמך — תזין אותו גם במסך הגדרת ה-Webhook ב-Meta
VERIFY_TOKEN=choose_any_secret_string
# מ-Meta for Developers > האפליקציה שלך > App Settings > Basic > App Secret
APP_SECRET=your_app_secret_here
# רק המספר שלך יורשה לדבר עם הבוט (פורמט בינלאומי בלי + או רווחים, לדוגמה 9725...)
ALLOWED_NUMBER=9725XXXXXXXX

# ===== Claude (Anthropic) =====
# מ-console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# מודל ברירת מחדל לפענוח עברית (זול ומהיר)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ===== כללי =====
PORT=3000
# היכן נשמרים הקבצים (ב-Render עם דיסק קבוע: /data)
DATA_DIR=./data
